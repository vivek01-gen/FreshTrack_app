<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Subtle transparent halo/backing for visual depth -->
    <path
        android:fillColor="#1FFFFFFF"
        android:pathData="M54,54 m-36,0 a36,36 0 1,1 72,0 a36,36 0 1,1 -72,0" />

    <!-- Outline of Clock Circle (Mint Green) -->
    <path
        android:strokeColor="#00C897"
        android:strokeWidth="3.2"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:pathData="M54,54 m-28,0 a28,28 0 1,1 56,0 a28,28 0 1,1 -56,0" />

    <!-- The Leaf Path on the left representing freshness -->
    <path
        android:fillColor="#00C897"
        android:pathData="M34,74 C20,60 20,44 34,34 C44,40 44,52 34,74 Z" />
        
    <!-- Leaf Spine (vein) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.2"
        android:strokeLineCap="round"
        android:pathData="M34,74 C31,60 31,48 34,34" />

    <!-- Hour Hand (pointing right-up) -->
    <path
        android:strokeColor="#00C897"
        android:strokeWidth="2.8"
        android:strokeLineCap="round"
        android:pathData="M54,54 L68,44" />

    <!-- Minute Hand (pointing left-up) -->
    <path
        android:strokeColor="#4ADE80"
        android:strokeWidth="2.2"
        android:strokeLineCap="round"
        android:pathData="M54,54 L44,36" />

    <!-- Center Pin (Hub) -->
    <path
        android:fillColor="#4ADE80"
        android:pathData="M54,54 m-4,0 a4,4 0 1,1 8,0 a4,4 0 1,1 -8,0" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,54 m-1.5,0 a1.5,1.5 0 1,1 3,0 a1.5,1.5 0 1,1 -3,0" />
        
