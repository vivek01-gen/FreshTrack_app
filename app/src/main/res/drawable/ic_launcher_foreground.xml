<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/apk/res/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Subtle Ambient Green/Cyan Underglow / Shadow plate behind the dial -->
    <path
        android:fillColor="#2510B981"
        android:pathData="M54,54 m-28,0 a28,28 0 1,1 56,0 a28,28 0 1,1 -56,0" />

    <!-- Pure Soft White High-Contrast Dial Background -->
    <path
        android:fillColor="#F8FFFE"
        android:strokeColor="#1510B981"
        android:strokeWidth="0.5"
        android:pathData="M54,54 m-26,0 a26,26 0 1,1 52,0 a26,26 0 1,1 -52,0" />

    <!-- Clock Ring in gorgeous premium Mint-to-Emerald Linear Gradient -->
    <path
        android:strokeWidth="3.2"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:pathData="M54,54 m-22.5,0 a22.5,22.5 0 1,1 45,0 a22.5,22.5 0 1,1 -45,0">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:angle="45"
                android:type="linear">
                <item android:color="#22D3EE" android:offset="0.0" />
                <item android:color="#34D399" android:offset="0.5" />
                <item android:color="#10B981" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Clock Leaf: Elegant Sprouting Leaf on Left Side -->
    <path
        android:pathData="M 37.8,70.2 C 24.1,63.2 24.1,44.8 37.8,37.8 C 44.8,49.4 44.8,58.6 37.8,70.2 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:angle="90"
                android:type="linear">
                <item android:color="#CFE8C9" android:offset="0.0" />
                <item android:color="#34D399" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Elegant sharp stroke to define leaf boundaries in Emerald Accent -->
    <path
        android:strokeColor="#10B981"
        android:strokeWidth="1.2"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 37.8,70.2 C 24.1,63.2 24.1,44.8 37.8,37.8 C 44.8,49.4 44.8,58.6 37.8,70.2 Z" />

    <!-- Soft Clean White Spine line (vein) to match native branding -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.0"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 37.8,70.2 C 36.5,58.6 36.5,49.4 37.8,37.8" />

    <!-- 12 O'Clock Tick Indicator -->
    <path
        android:strokeColor="#10B981"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:pathData="M 54,34.7 L 54,31.0" />

    <!-- 3 O'Clock Tick Indicator -->
    <path
        android:strokeColor="#10B981"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:pathData="M 73.3,54 L 77.0,54" />

    <!-- 6 O'Clock Tick Indicator -->
    <path
        android:strokeColor="#10B981"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:pathData="M 54,73.3 L 54,77.0" />

    <!-- Elegant Hour Hand (Pointing to 2 o'clock, Emerald Accent) -->
    <path
        android:strokeColor="#10B981"
        android:strokeWidth="2.2"
        android:strokeLineCap="round"
        android:pathData="M 54,54 L 62.0,47.8" />

    <!-- Elegant Minute Hand (Pointing to 10 o'clock, Soft Mint) -->
    <path
        android:strokeColor="#22D3EE"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M 54,54 L 42.0,44.0" />

    <!-- Center Pin Hub with Emerald core -->
    <path
        android:fillColor="#10B981"
        android:pathData="M 54,54 m -2.5,0 a 2.5,2.5 0 1,1 5,0 a 2.5,2.5 0 1,1 -5,0" />

    <!-- Inner White Highlight Dot on Pivot center -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 54,54 m -1.1,0 a 1.1,1.1 0 1,1 2.2,0 a 1.1,1.1 0 1,1 -2.2,0" />

</vector>
